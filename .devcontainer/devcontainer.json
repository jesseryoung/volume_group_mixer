{
    "name": "Volume Group Mixer StreamController Plugin",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },
    "postCreateCommand": "bash .devcontainer/setup-claude.sh",
    "runArgs": [
        "--userns=keep-id",
        "--security-opt=label=type:container_runtime_t"
    ],
    "containerEnv": {
        "XDG_RUNTIME_DIR": "/tmp",
        "PIPEWIRE_RUNTIME_DIR": "/tmp",
        "PULSE_SERVER": "unix:/tmp/pulse/native"
    },
    "mounts": [
        {
            "source": "${localEnv:XDG_RUNTIME_DIR}/pipewire-0",
            "target": "/tmp/pipewire-0",
            "type": "bind"
        },
        {
            "source": "${localEnv:XDG_RUNTIME_DIR}/pulse/native",
            "target": "/tmp/pulse/native",
            "type": "bind"
        },
        {
            "source": "claude-auth",
            "target": "/claude-auth",
            "type": "volume"
        }
    ],
    "remoteUser": "vscode"
}
